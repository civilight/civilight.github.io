{
	"$schema": "https://biomejs.dev/schemas/1.7.0/schema.json",
	"organizeImports": {
		"enabled": true
	},

	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExportsInTest": "off",
				"noEmptyInterface": "off"
			},
			"style": {
				"noInferrableTypes": "off"
			}
		}
	},

	"formatter": {
		"lineWidth": 100,
		"indentWidth": 4,
		"indentStyle": "tab"
	},

	"javascript": {
		"formatter": {
			"semicolons": "asNeeded"
		}
	}
}
